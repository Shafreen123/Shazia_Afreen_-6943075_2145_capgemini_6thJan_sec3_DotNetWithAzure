@model IEnumerable<UniversityManagement.Models.Course>

<h2>Courses</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Add New Course</a>
</p>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Credits</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.CourseId</td>
                <td>@item.Title</td>
                <td>@item.Credits</td>

                <td>

                    <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-warning">Edit</a>

                    <a asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-info">Details</a>

                    <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-danger">Delete</a>

                </td>

            </tr>
        }

    </tbody>

</table>