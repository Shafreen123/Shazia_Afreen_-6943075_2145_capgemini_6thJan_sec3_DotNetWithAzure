@model IEnumerable<UniversityManagement.Models.Student>

<h2>Students</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Student</a>
</p>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Enrollment Date</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentId</td>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.EnrollmentDate</td>

                <td>

                    <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-warning">Edit</a>

                    <a asp-action="Details" asp-route-id="@item.StudentId" class="btn btn-info">Details</a>

                    <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-danger">Delete</a>

                </td>

            </tr>
        }

    </tbody>

</table>