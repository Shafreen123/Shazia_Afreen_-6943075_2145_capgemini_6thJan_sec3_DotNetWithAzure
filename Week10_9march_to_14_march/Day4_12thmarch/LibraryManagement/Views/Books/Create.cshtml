<form method="post">

    <label>Id</label>
    <input asp-for="Id" />

    <br />

    <label>Title</label>
    <input asp-for="Title" />

    <br />

    <label>Author</label>
    <input asp-for="Author" />

    <br />

    <button type="submit">Add Book</button>

</form>