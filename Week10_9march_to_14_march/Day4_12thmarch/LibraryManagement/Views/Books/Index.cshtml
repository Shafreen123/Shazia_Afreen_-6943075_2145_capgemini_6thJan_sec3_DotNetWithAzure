@model List<LibraryManagement.Models.Book>

<h2>Books List</h2>

<a href="/Books/Create">Add New Book</a>

<table border="1" cellpadding="10">
    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Author</th>
        <th>Action</th>
    </tr>

    @foreach (var book in Model)
    {
        <tr>
            <td>@book.Id</td>
            <td>@book.Title</td>
            <td>@book.Author</td>
            <td>
                <a href="/Books/Edit/@book.Id">Edit</a> |
                <a href="/Books/Delete/@book.Id">Delete</a>
            </td>
        </tr>
    }

</table>