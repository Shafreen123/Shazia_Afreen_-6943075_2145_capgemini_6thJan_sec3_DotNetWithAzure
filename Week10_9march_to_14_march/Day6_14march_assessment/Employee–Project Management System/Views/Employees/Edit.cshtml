@model Employee_Project_Management_System.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<h2>Edit Employee</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="EmployeeId" />

    <div class="mb-3">
        <label asp-for="FullName"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DepartmentId">Department</label>
        <select asp-for="DepartmentId" asp-items="ViewBag.Departments"
                class="form-select">
            <option value="">-- Select Department --</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Assign Projects</label>
        <select name="selectedProjects" asp-items="ViewBag.Projects"
                class="form-select" multiple></select>
        <small class="text-muted">Hold Ctrl to select multiple projects</small>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>