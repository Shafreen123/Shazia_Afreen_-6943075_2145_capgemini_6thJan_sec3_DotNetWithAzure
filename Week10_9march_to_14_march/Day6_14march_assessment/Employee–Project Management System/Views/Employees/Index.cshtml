@model IEnumerable<Employee_Project_Management_System.Models.Employee>

<h2>Employees</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ New Employee</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Projects</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.FullName</td>
                <td>@emp.Email</td>
                <td>@emp.Department?.DepartmentName</td>
                <td>
                    @string.Join(", ", emp.EmployeeProjects.Select(ep => ep.Project.Title))
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@emp.EmployeeId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@emp.EmployeeId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
