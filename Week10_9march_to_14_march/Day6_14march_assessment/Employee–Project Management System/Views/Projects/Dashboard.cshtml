@model IEnumerable<Employee_Project_Management_System.Models.Project>

<h2>Project Dashboard</h2>

@foreach (var project in Model)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">@project.Title</h4>
        </div>
        <div class="card-body">
            <p class="text-muted">@project.Description</p>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Assigned Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ep in project.EmployeeProjects)
                    {
                        <tr>
                            <td>@ep.Employee.FullName</td>
                            <td>@ep.Employee.Department?.DepartmentName</td>
                            <td>@ep.AssignedDate.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
