@model IEnumerable<Employee_Project_Management_System.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<h2>Projects</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ New Project</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Assigned Employees</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Title</td>
                <td>@project.Description</td>
                <td>
                    @string.Join(", ", project.EmployeeProjects.Select(ep => ep.Employee.FullName))
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@project.ProjectId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@project.ProjectId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>