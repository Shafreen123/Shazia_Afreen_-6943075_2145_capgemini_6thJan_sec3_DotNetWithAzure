@model LoginViewModel
@{
    ViewData["Title"] = "Student Login";
}
 
<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg p-4" style="width: 420px;">
 
        <div class="text-center mb-4">
            <div class="bg-success text-white rounded-circle d-inline-flex p-3 mb-2">
                <i class="bi bi-shield-lock-fill fs-3"></i>
            </div>
            <h2 class="fw-bold">Welcome Back</h2>
            <p class="text-muted">Sign in to your account</p>
        </div>
 
        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="alert alert-danger small"></div>
 
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" />
            </div>
 
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control" type="password" />
            </div>
 
            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
            </div>
 
            <button type="submit" class="btn btn-success w-100 py-2 fw-bold">Login</button>
        </form>
 
        <p class="text-center mt-3 mb-0">
            New student? <a asp-action="Register">Register here</a>
        </p>
    </div>
</div>
