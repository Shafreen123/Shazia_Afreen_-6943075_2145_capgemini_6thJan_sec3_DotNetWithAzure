<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FirstExample</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FirstExample.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">
                    Student Portal
                </a>
 
                <div class="d-flex gap-2">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <a class="btn btn-outline-light btn-sm" asp-action="Dashboard" asp-controller="Home">
                            Dashboard
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="btn btn-warning btn-sm" asp-action="AdminPanel" asp-controller="Home">
                                Admin Panel
                            </a>
                        }
                        <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                            <button class="btn btn-danger btn-sm">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-action="Register" asp-controller="Account">
                            Register
                        </a>
                        <a class="btn btn-success btn-sm" asp-action="Login" asp-controller="Account">
                            Login
                        </a>
                    }
                </div>
            </div>
        </nav>

    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - FirstExample - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
