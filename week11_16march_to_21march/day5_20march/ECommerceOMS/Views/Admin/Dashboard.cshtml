@model ECommerceOMS.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="bi bi-speedometer2 text-warning"></i> Admin Dashboard
    </h2>
    <span class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
</div>


<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 small">Pending Orders</p>
                    <h2 class="fw-bold mb-0">@Model.PendingOrders.Count</h2>
                </div>
                <i class="bi bi-clock-history" style="font-size:2.5rem;opacity:0.6"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 small">Total Customers</p>
                    <h2 class="fw-bold mb-0">@Model.CustomerSummaries.Count</h2>
                </div>
                <i class="bi bi-people" style="font-size:2.5rem;opacity:0.6"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning shadow">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 small">Top Products</p>
                    <h2 class="fw-bold mb-0">@Model.TopProducts.Count</h2>
                </div>
                <i class="bi bi-trophy" style="font-size:2.5rem;opacity:0.6"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger shadow">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 small">Total Revenue</p>
                    <h2 class="fw-bold mb-0">
                        ₹@Model.PendingOrders.Sum(o => o.TotalAmount).ToString("F0")
                    </h2>
                </div>
                <i class="bi bi-currency-rupee" style="font-size:2.5rem;opacity:0.6"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
  
    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header bg-dark text-white fw-bold">
                <i class="bi bi-trophy-fill text-warning"></i> Top 5 Selling Products
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Rank</th>
                            <th>Product</th>
                            <th>Sold</th>
                            <th>Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rank = 1;
                        }
                        @foreach (var p in Model.TopProducts)
                        {
                            <tr>
                                <td>
                                    <span class="badge @(rank == 1 ? "bg-warning text-dark" :
                                                                                                                                           rank == 2 ? "bg-secondary" :
                                                                                                                                                       "bg-light text-dark")">
                                        #@rank
                                    </span>
                                </td>
                                <td>@p.ProductName</td>
                                <td><span class="badge bg-primary">@p.TotalSold</span></td>
                                <td class="text-success fw-bold">₹@p.Revenue.ToString("F2")</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

   
    <div class="col-md-6">
        <div class="card shadow h-100">
            <div class="card-header bg-danger text-white fw-bold">
                <i class="bi bi-truck"></i> Pending Shipments
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.PendingOrders)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">#@o.OrderId</span>
                                </td>
                                <td>@o.Customer?.FirstName @o.Customer?.LastName</td>
                                <td>@o.OrderDate.ToString("dd MMM")</td>
                                <td>
                                    <form asp-action="UpdateShipping" method="post">
                                        <input type="hidden" name="shippingId"
                                               value="@o.ShippingDetail?.ShippingId" />
                                        <input type="hidden" name="status" value="Shipped" />
                                        <button class="btn btn-sm btn-success">
                                            <i class="bi bi-truck"></i> Ship
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<div class="card shadow">
    <div class="card-header bg-info text-white fw-bold">
        <i class="bi bi-people-fill"></i> Customer Order Summary
    </div>
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-light">
                <tr>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Total Orders</th>
                    <th>Total Spent</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.CustomerSummaries)
                {
                    <tr>
                        <td>
                            <i class="bi bi-person-circle text-primary"></i>
                            @s.Customer.FirstName @s.Customer.LastName
                        </td>
                        <td>@s.Customer.Email</td>
                        <td>
                            <span class="badge bg-primary">@s.OrderCount orders</span>
                        </td>
                        <td class="text-success fw-bold">
                            ₹@s.TotalSpent.ToString("F2")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>