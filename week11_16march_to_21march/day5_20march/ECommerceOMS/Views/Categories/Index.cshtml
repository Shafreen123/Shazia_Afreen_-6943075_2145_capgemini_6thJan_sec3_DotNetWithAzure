@model IEnumerable<ECommerceOMS.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-tags text-primary"></i> Categories</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add Category
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var c in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-tag-fill text-warning"></i> @c.Name
                </div>
                <div class="card-body">
                    <p class="text-muted">@c.Description</p>
                    <span class="badge bg-primary">
                        @c.Products?.Count() products
                    </span>
                </div>
                <div class="card-footer bg-white d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@c.CategoryId"
                           class="btn btn-sm btn-outline-warning w-100">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@c.CategoryId"
                           class="btn btn-sm btn-outline-danger w-100">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </div>
            </div>
        </div>
    }
</div>