@model IEnumerable<ECommerceOMS.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-receipt text-primary"></i> Orders</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> New Order
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Order Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">#@o.OrderId</span></td>
                        <td>
                            <i class="bi bi-person-circle text-primary"></i>
                            @o.Customer?.FirstName @o.Customer?.LastName
                        </td>
                        <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                        <td class="fw-bold text-success">₹@o.TotalAmount.ToString("F2")</td>
                        <td>
                            @{
                                var badgeClass = o.Status.ToString() switch
                                {
                                    "Pending" => "bg-warning text-dark",
                                    "Processing" => "bg-info text-dark",
                                    "Shipped" => "bg-primary",
                                    "Delivered" => "bg-success",
                                    "Cancelled" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@o.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@o.OrderId"
                                   class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@o.OrderId"
                                   class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3 text-center">
        No orders yet. <a asp-action="Create">Create the first order.</a>
    </div>
}