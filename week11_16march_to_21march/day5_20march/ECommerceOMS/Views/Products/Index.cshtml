@model ECommerceOMS.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-box-seam text-primary"></i> Products</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add Product
    </a>
</div>

<div class="card mb-4 p-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label fw-semibold">Search</label>
            <input type="text" name="search" value="@Model.SearchTerm"
                   class="form-control" placeholder="Search by product name..." />
        </div>
        <div class="col-md-4">
            <label class="form-label fw-semibold">Category</label>
            <select name="categoryId" class="form-select">
                <option value="">-- All Categories --</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.CategoryId"
                            selected="@(Model.SelectedCategoryId == cat.CategoryId)">
                        @cat.Name
                    </option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100" type="submit">
                <i class="bi bi-funnel"></i> Filter
            </button>
        </div>
    </form>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var p in Model.Products)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white d-flex
                    justify-content-between align-items-center">
                    <span class="fw-bold">@p.Name</span>
                    <span class="badge bg-light text-dark">@p.Category?.Name</span>
                </div>
                <div class="card-body">
                    <p class="text-muted small">@p.Description</p>
                    <h4 class="text-success fw-bold">₹@p.Price.ToString("F2")</h4>
                    <p class="mb-1">
                        <i class="bi bi-archive"></i>
                        Stock:
                        <span class="badge @(p.Stock > 10 ? "bg-success" :
                                                                                                       p.Stock > 0 ? "bg-warning text-dark" :
                                                                                                                      "bg-danger")">
                            @p.Stock units
                        </span>
                    </p>
                </div>
                <div class="card-footer bg-white d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@p.ProductId"
                           class="btn btn-sm btn-outline-info w-100">
                        <i class="bi bi-eye"></i> View
                    </a>
                    <a asp-action="Edit" asp-route-id="@p.ProductId"
                           class="btn btn-sm btn-outline-warning w-100">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@p.ProductId"
                           class="btn btn-sm btn-outline-danger w-100">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-warning mt-4 text-center">
        <i class="bi bi-exclamation-triangle"></i>
        No products found. <a asp-action="Create">Add one now.</a>
    </div>
}