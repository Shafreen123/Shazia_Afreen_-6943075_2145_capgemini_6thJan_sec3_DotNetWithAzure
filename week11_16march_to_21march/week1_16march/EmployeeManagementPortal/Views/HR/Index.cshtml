@{
    ViewData["Title"] = "HR Dashboard";
}

<div class="container mt-4">
    <h2>🏢 HR Dashboard</h2>

    <div class="row mt-3">
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-primary shadow">
                <div class="card-body text-center p-4">
                    <h6>Total Employees</h6>
                    <h2>@ViewBag.TotalEmployees</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="EmployeeList"
           class="btn btn-info me-2">👥 Employee List</a>
        <a asp-action="Reports"
           class="btn btn-warning me-2">📊 Reports</a>
        <a asp-controller="Employee"
           asp-action="Register"
           class="btn btn-success">+ Add Employee</a>
    </div>
</div>