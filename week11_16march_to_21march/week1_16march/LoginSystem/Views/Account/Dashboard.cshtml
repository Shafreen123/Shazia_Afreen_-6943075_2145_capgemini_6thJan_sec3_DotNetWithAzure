@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    @* Welcome banner *@
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <div>
            <h4>👋 Welcome, <strong>@ViewBag.Username</strong>!</h4>
            <small>Role: <strong>@ViewBag.Role</strong></small>
        </div>
        <a asp-action="Logout" class="btn btn-danger">🚪 Logout</a>
    </div>

    @* Dashboard cards *@
    <div class="row mt-4">
        <div class="col-md-4 mb-3">
            <div class="card border-primary shadow-sm">
                <div class="card-body text-center">
                    <h1>👤</h1>
                    <h5>Profile</h5>
                    <p class="text-muted">@ViewBag.Username</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success shadow-sm">
                <div class="card-body text-center">
                    <h1>🛡️</h1>
                    <h5>Role</h5>
                    <p class="text-muted">@ViewBag.Role</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-warning shadow-sm">
                <div class="card-body text-center">
                    <h1>🕐</h1>
                    <h5>Session</h5>
                    <p class="text-muted">Active (30 min)</p>
                </div>
            </div>
        </div>
    </div>

    @* Logout button at bottom *@
    <div class="mt-3">
        <a asp-action="Logout" class="btn btn-outline-danger">
            🚪 Logout
        </a>
    </div>

</div>