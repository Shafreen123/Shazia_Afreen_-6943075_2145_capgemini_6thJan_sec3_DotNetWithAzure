@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="alert alert-success d-flex
                justify-content-between align-items-center">
        <div>
            <h4>👋 Welcome, <strong>@ViewBag.Username</strong>!</h4>
            <small>Role: <strong>@ViewBag.Role</strong></small>
        </div>
        <a asp-action="Logout" class="btn btn-danger">🚪 Logout</a>
    </div>

    @* Quick navigation cards *@
    <div class="row mt-4">
        <div class="col-md-6 mb-3">
            <div class="card border-primary shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <h1>🎓</h1>
                    <h5>Students</h5>
                    <p class="text-muted">Register and view students</p>
                    <a asp-controller="Student"
                       asp-action="Index"
                       class="btn btn-primary">Go to Students</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card border-success shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <h1>🛒</h1>
                    <h5>Products</h5>
                    <p class="text-muted">Manage product listings</p>
                    <a asp-controller="Product"
                       asp-action="Index"
                       class="btn btn-success">Go to Products</a>
                </div>
            </div>
        </div>
    </div>
</div>