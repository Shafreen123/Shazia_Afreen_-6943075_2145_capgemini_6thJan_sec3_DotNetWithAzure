<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventBooking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">🎟 EventBooking</a>
        <div class="ms-auto d-flex align-items-center gap-2" id="navButtons">
            <a class="btn btn-outline-light btn-sm" href="/Events">Events</a>
            <a class="btn btn-outline-light btn-sm" href="/Booking">My Bookings</a>
            <a class="btn btn-outline-warning btn-sm d-none" id="adminNavBtn" href="/Admin">⚙ Admin</a>
            <button class="btn btn-warning btn-sm d-none" id="logoutBtn" onclick="logout()">🚪 Logout</button>
            <a class="btn btn-warning btn-sm" id="loginNavBtn" href="/Login">Login</a>
        </div>
    </div>
</nav>
<div class="container mt-4">
    @RenderBody()
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// Show/hide login vs logout button based on token
(function() {
    const token = localStorage.getItem('jwt_token');
    if (token) {
        document.getElementById('logoutBtn').classList.remove('d-none');
        document.getElementById('loginNavBtn').classList.add('d-none');
        // Check if admin by decoding JWT
        try {
            const payload = JSON.parse(atob(token.split('.')[1]));
            if (payload['IsAdmin'] === 'True') {
                document.getElementById('adminNavBtn').classList.remove('d-none');
            }
        } catch(e) {}
    }
})();

function logout() {
    localStorage.removeItem('jwt_token');
    window.location.href = '/Login';
}
</script>
@RenderSection("Scripts", required: false)
</body>
</html>