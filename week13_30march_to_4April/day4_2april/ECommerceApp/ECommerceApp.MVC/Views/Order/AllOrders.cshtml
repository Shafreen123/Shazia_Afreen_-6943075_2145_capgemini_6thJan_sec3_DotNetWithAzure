@model List<ECommerceApp.MVC.ViewModels.OrderViewModel>
@{ ViewData["Title"] = "All Orders (Admin)"; }

<h2 class="mb-4">📋 All Orders <span class="badge bg-warning text-dark">Admin View</span></h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No orders placed yet.
        <a asp-controller="Product" asp-action="Index">Browse products →</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th>Items</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><strong>#@order.Id</strong></td>
                        <td>👤 @(string.IsNullOrEmpty(order.UserFullName) ? "User #" + order.UserId : order.UserFullName)</td>
                        <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge @(order.Status == "Delivered" ? "bg-success" :
                                               order.Status == "Shipped"    ? "bg-info"    :
                                               order.Status == "Cancelled"  ? "bg-danger"  : "bg-warning text-dark")">
                                @order.Status
                            </span>
                        </td>
                        <td class="fw-bold text-success">₹@order.TotalAmount.ToString("0.00")</td>
                        <td>@order.Items.Count item(s)</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-dark">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card mt-3 border-0 bg-light">
        <div class="card-body d-flex gap-4">
            <div>
                📦 Total Orders: <strong>@Model.Count</strong>
            </div>
            <div>
                💰 Total Revenue: <strong class="text-success">₹@Model.Sum(o => o.TotalAmount).ToString("0.00")</strong>
            </div>
            <div>
                ⏳ Pending: <strong class="text-warning">@Model.Count(o => o.Status == "Pending")</strong>
            </div>
            <div>
                ✅ Delivered: <strong class="text-success">@Model.Count(o => o.Status == "Delivered")</strong>
            </div>
        </div>
    </div>
}