@model ECommerceApp.MVC.ViewModels.PlaceOrderViewModel
@{ ViewData["Title"] = "Place Order"; }

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <h4>🛒 Place Order</h4>
            </div>
            <div class="card-body">
                <form asp-action="Place" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <input type="hidden" asp-for="ProductId" />
                    <div class="mb-3">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" max="100" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ShippingAddress" class="form-label"></label>
                        <textarea asp-for="ShippingAddress" class="form-control" rows="3"
                                  placeholder="Enter your full shipping address"></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-dark w-100">✅ Confirm Order</button>
                    <a asp-controller="Product" asp-action="Index"
                       class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>