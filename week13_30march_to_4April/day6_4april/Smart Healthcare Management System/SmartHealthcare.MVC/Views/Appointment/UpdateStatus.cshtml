@model SmartHealthcare.MVC.Models.AppointmentViewModel
@{ ViewData["Title"] = "Update Appointment"; }

<h2>Appointment #@Model.Id</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">Appointment Details</div>
            <div class="card-body">
                <p><strong>Patient:</strong> @Model.PatientName</p>
                <p><strong>Doctor:</strong> @Model.DoctorName</p>
                <p><strong>Date:</strong> @Model.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")</p>
                <p><strong>Current Status:</strong>
                    <span class="badge bg-warning text-dark">@Model.Status</span>
                </p>
                <hr />
                <p class="mb-1"><strong>Symptoms reported by patient:</strong></p>
                <div class="p-3 bg-light rounded border">
                    @if (!string.IsNullOrEmpty(Model.Symptoms))
                    {
                        <p class="mb-0">@Model.Symptoms</p>
                    }
                    else
                    {
                        <p class="mb-0 text-muted">No symptoms provided.</p>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <p class="mt-3 mb-1"><strong>Additional Notes:</strong></p>
                    <p>@Model.Notes</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-5 offset-md-1">
        <div class="card">
            <div class="card-header bg-primary text-white">Update Status</div>
            <div class="card-body">
                <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">New Status</label>
                        <select name="status" class="form-select">
                            <option value="Scheduled"  >Scheduled</option>
                            <option value="InProgress" >In Progress</option>
                            <option value="Completed"  >Completed</option>
                            <option value="Cancelled"  >Cancelled</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Save Status</button>
                </form>
            </div>
        </div>
    </div>
</div>