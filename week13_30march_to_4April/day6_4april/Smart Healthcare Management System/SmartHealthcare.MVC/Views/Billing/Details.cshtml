@model SmartHealthcare.MVC.Models.BillViewModel
@{ ViewData["Title"] = $"Bill #{Model.Id}"; }

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-dark text-white d-flex justify-content-between">
                <h5 class="mb-0">🏥 Smart Healthcare — Bill Receipt</h5>
                <span>Bill #@Model.Id</span>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-6">
                        <strong>Patient:</strong> @Model.PatientName
                    </div>
                    <div class="col-6">
                        <strong>Doctor:</strong> @Model.DoctorName
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-6">
                        <strong>Appointment ID:</strong> #@Model.AppointmentId
                    </div>
                    <div class="col-6">
                        <strong>Generated:</strong> @Model.GeneratedAt.ToString("dd MMM yyyy, hh:mm tt")
                    </div>
                </div>
                <hr />
                <div class="mb-2">
                    <strong>Description / Services:</strong><br />
                    @(string.IsNullOrEmpty(Model.Description) ? "General consultation" : Model.Description)
                </div>
                <hr />
                <div class="row">
                    <div class="col-6">
                        <h4 class="text-success">₹@Model.Amount.ToString("N2")</h4>
                    </div>
                    <div class="col-6 text-end">
                        @{
                            var badgeClass = Model.Status switch
                            {
                                "Paid"      => "bg-success",
                                "Cancelled" => "bg-danger",
                                _           => "bg-warning text-dark"
                            };
                        }
                        <span class="badge @badgeClass fs-6">@Model.Status</span>
                        @if (Model.PaidAt.HasValue)
                        {
                            <br /><small class="text-muted">Paid on @Model.PaidAt.Value.ToString("dd MMM yyyy")</small>
                        }
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Index" class="btn btn-secondary">← Back to Bills</a>
                @if (ViewBag.Role == "Admin" && Model.Status == "Pending")
                {
                    <form asp-action="MarkPaid" asp-route-id="@Model.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-success"
                                onclick="return confirm('Mark as Paid?')">Mark as Paid</button>
                    </form>
                    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-warning"
                                onclick="return confirm('Cancel this bill?')">Cancel Bill</button>
                    </form>
                }
                <button onclick="window.print()" class="btn btn-outline-dark ms-auto">🖨 Print</button>
            </div>
        </div>
    </div>
</div>