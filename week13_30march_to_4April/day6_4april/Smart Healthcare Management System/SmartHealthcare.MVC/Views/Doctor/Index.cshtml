@model List<SmartHealthcare.MVC.Models.DoctorViewModel>
@{ ViewData["Title"] = "Doctors"; }
<div class="container mt-4">
    <h3>Our Doctors</h3>
    <hr/>
    <div class="row g-3">
        @foreach (var d in Model)
        {
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">@d.FullName</h5>
                    <p class="text-muted mb-1">@string.Join(", ", d.Specializations)</p>
                    <p><strong>Experience:</strong> @d.ExperienceYears years</p>
                    <p><strong>Phone:</strong> @d.Phone</p>
                    <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-outline-primary btn-sm">View Details</a>
                </div>
            </div>
        </div>
        }
    </div>
</div>
