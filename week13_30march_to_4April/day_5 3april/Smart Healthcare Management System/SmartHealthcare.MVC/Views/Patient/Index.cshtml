@model List<SmartHealthcare.MVC.Models.PatientViewModel>
@{ ViewData["Title"] = "Patients"; }
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>All Patients</h3>
        <a asp-action="Create" class="btn btn-primary">+ Add Patient</a>
    </div>
    @if (!Model.Any())
    {
        <div class="alert alert-info">No patients found. Click "Add Patient" to add one.</div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Phone</th>
                    <th>Gender</th>
                    <th>Date of Birth</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.FullName</td>
                    <td>@p.Phone</td>
                    <td>@p.Gender</td>
                    <td>@p.DateOfBirth.ToString("dd MMM yyyy")</td>
                    <td>@p.Address</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@p.Id"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Delete this patient?')">Delete</a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    }
</div>
